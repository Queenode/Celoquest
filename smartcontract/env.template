# Deployer Private Key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Address that will sign progress vouchers
REWARD_SIGNER=0xYourRewardSignerAddress

# Celo Network RPC URLs
# Mainnet: https://forno.celo.org
# Alfajores Testnet: https://alfajores-forno.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Celo Explorer API Key (optional, for contract verification)
# Get one at: https://celoscan.io
CELOSCAN_API_KEY=your_api_key_here
